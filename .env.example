# 백엔드 환경변수 (.env 파일로 복사 후 실제 값을 채운다)

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# 주의: 모델명은 env 가 아니라 코드 상수 (임베딩: search_vector.py·embeddings_v1.py,
# 답변: answer.py). 임베딩 모델을 env 로 바꾸면 질의/코퍼스 임베딩 공간이 어긋나
# 검색이 조용히 망가지므로, 모델 교체는 전량 재임베딩과 함께 코드에서 바꾼다.

# PostgreSQL + pgvector
DATABASE_URL=postgresql://user:password@host:5432/national_assembly

# CORS 허용 출처 (쉼표 구분). 비우면 개발 기본값 (localhost:5173, 127.0.0.1:5173)
BACKEND_CORS_ORIGINS=

# 프론트엔드 환경변수 (frontend/.env 파일로 별도 관리)
# VITE_API_URL=http://127.0.0.1:8000  # 비우면 기본 127.0.0.1:8000 (Windows 는 localhost 금지 — IPv6 +2초)

# 열린국회정보 Open API (open.assembly.go.kr — 의원 인적사항·정당, 3단계 정당 모듈용)
OPEN_ASSEMBLY=your_open_assembly_api_key_here

# Grounding 사전차단 임계 (무작위 유사도 기준선 0.386 실측 — 조정 가능)
GROUNDING_SIM_THRESHOLD=0.4

# 재순위(reranker) — OpenAI LLM listwise rerank 로 하이브리드 상위 30 후보 재정렬 (선택).
# 기본 OFF. RERANKER_ENABLED=1 이면 OPENAI_API_KEY 를 재사용 (별도 키 불필요).
# OFF 면 무해하게 기존 RRF 순위 사용. 질문당 gpt-4o-mini 호출 1회 추가.
RERANKER_ENABLED=0
