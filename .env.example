# 백엔드 환경변수 (.env 파일로 복사 후 실제 값을 채운다)

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# PostgreSQL + pgvector
DATABASE_URL=postgresql://user:password@host:5432/national_assembly

# 서버 설정
BACKEND_CORS_ORIGINS=http://localhost:5173

# 프론트엔드 환경변수 (frontend/.env 파일로 별도 관리)
# VITE_API_URL=http://localhost:8000

# 열린국회정보 Open API (open.assembly.go.kr — 의원 인적사항·정당, 3단계 정당 모듈용)
OPEN_ASSEMBLY=your_open_assembly_api_key_here

# Grounding 사전차단 임계 (무작위 유사도 기준선 0.386 실측 — 조정 가능)
GROUNDING_SIM_THRESHOLD=0.4
